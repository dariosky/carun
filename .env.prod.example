APP_ENV=prod
DEBUG=false
DATABASE_URL=postgresql+psycopg://carun_user:replace_me@127.0.0.1:5432/carun
SESSION_SECRET=replace-with-long-random-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.example/api/auth/google/callback
WEBSERVER=your-domain.example
SSH_USER=opalstack-user
SSH_PORT=22
APP_DIR=/home/opalstack/apps/carun
RESTART_CMD=supervisorctl restart carun-api
HEALTHCHECK_URL=https://your-domain.example/api/health
