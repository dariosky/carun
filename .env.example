APP_ENV=local
DEBUG=true
WEBSERVER_PORT=8080
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/carun
SESSION_SECRET=dev-session-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_BUILD_ID=dev
FRONTEND_BUILD_LABEL=v.dev
WEBSERVER=example.com
SSH_USER=example_user
SSH_PORT=22
UV_REMOTE_PATH=/home/example/apps/carun.venv/bin/uv
APP_DIR=/home/example/apps/carun
RESTART_CMD=supervisorctl restart carun-api
HEALTHCHECK_URL=https://example.com/api/health
